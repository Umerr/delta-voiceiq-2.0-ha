# Copy to /config/secrets.yaml and fill in your values
# NEVER commit your real secrets.yaml to git!

# VoiceIQ JWT (from mitmproxy capture)
delta_token: "Bearer YOUR_TOKEN_HERE"

# Faucet MAC (from mitmproxy UserInfo or printed on module)
delta_mac_address: "XXXXXXXXXXXX"

# VoiceIQ user ID (from mitmproxy UserInfo)
delta_user_id: "your_user_id_here"
